# Ignore everything by default
*

# Track only these
!.gitignore
!CLAUDE.md
!README.md
!cliff.toml
!CHANGELOG.md
!.github/
!.github/**
!.claude/
!.claude/**
!agent-memory/
!agent-memory/**
!skills/
!skills/**
!scripts/
!scripts/**
!rules/
!rules/**
!.kiro/
!.kiro/**
!hooks/
!hooks/**
!GRAPH_REPORT.md
!GRAPHIFY_USAGE.md
!graphify-out/
!graphify-out/GRAPH_REPORT.md
!graphify-out/graph.html
!graphify-out/graph.json
!graphify-out/manifest.json
!commands/**
!commands/
!statusline-command.sh

# Personal sync scripts (contain company-specific replace patterns — do not commit)
scripts/sync-skills-to-claude.sh

# Personal health/fitness logs (PII — do not commit)
skills/fitness/personal/

# Re-ignore noise inside tracked folders
**/.DS_Store
skills/**/_internal/
skills/.claude/
skills/**/.claude/
.claude/worktrees/
.claude/settings.local.json
agent-memory/skill-usage.log
hooks/__pycache__/
