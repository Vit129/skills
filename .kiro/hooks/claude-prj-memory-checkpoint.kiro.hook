{
  "name": "Claude Prj — Memory Checkpoint",
  "version": "2.0.0",
  "description": "After spec task completes: update Task_Ledger in memory.md if a real artifact was produced.",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "askAgent",
    "prompt": "[WORKSPACE GUARD: Only execute if the current session context involves files in '.claude/' workspace. If the user is working exclusively in 'VitProjects/' workspace, skip silently.] A spec task just completed. If it produced a real artifact (file created, phase completed, decision made) — update agent-memory/memory.md Task_Ledger entry for this task. If the task was Q&A only or produced no artifact → skip. Report only if something changed: 📝 Checkpoint: [task] [status]."
  }
}
