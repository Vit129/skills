{
  "name": "Gemini Agent Memory — Session Load",
  "version": "3.1.0",
  "description": "Load Markdown Memory Palace and Knowledge context on first prompt for Gemini CLI. Skip if already loaded.",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Check if Agent Memory is already loaded in this conversation (look for 'Agent Memory loaded' or prior palace/knowledge context). If YES → do nothing, silent.\n\nIf NO:\n\n1. Determine memory root:\n- Use /Users/supavit.cho/.gemini/agent-memory/ for global context.\n- If in a project, use {workspace_root}/agent-memory/.\n\n2. Bootstrap if missing using Markdown only (palace/state.md, etc.). Do not create JSON files.\n\n3. Read silently:\n- palace/state.md\n- palace/user-profile.md if present\n- knowledge/index.md\n- knowledge/evolution.md\n\n4. Score-based knowledge routing from knowledge/index.md.\n\n5. Brief the user concisely on last session and relevant knowledge."
  }
}
