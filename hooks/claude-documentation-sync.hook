{
  "name": "Global Claude Documentation Sync",
  "version": "2.0.0",
  "description": "Final Session Sync: Update documentation before closing session (ideal for release/deploy prep).",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "askAgent",
    "prompt": "1. Find workspace root. 2. Check for agent-memory/ directory. If not found, EXIT. 3. Analyze all changes in this session. Determine if they represent completed features, version-worthy shifts, or architectural changes. 4. ACTION: Update relevant documentation (e.g., docs/Requirements/ or docs/Architecture/) to reflect the 'final state' of this session. 5. If versioning/release is implied, ensure the documentation is ready for a bump/deploy summary. Silent if no significant changes worth documenting."
  }
}
