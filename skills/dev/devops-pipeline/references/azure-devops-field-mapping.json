{
  "work_item_types": {
    "pbi": {
      "type": "Product Backlog Item",
      "fields": {
        "System.Title": "{{PBI.Title}}",
        "System.Description": "{{PBI.Description|newlines}}",
        "System.AcceptanceCriteria": "{{Requirements|newlines}}",
        "Microsoft.VSTS.Common.BusinessValue": "{{Product Metrics|newlines}}",
        "Custom.Goal": "{{Goal|newlines}}",
        "Custom.Persona": "{{Persona|newlines}}",
        "Custom.UXUIReference": "{{UX/UI Reference|newlines}}",
        "Custom.UserFlow": "{{User Flow|newlines}}",
        "System.State": "New",
        "System.Reason": "New backlog item"
      }
    },
    "task": {
      "type": "Task",
      "fields": {
        "System.Title": "{{Task.Title}}",
        "System.Description": "{{Task.Description|newlines}}",
        "System.Parent": "{{PBI.ID}}",
        "System.State": "To Do",
        "System.Reason": "New task",
        "Microsoft.VSTS.Scheduling.RemainingWork": "8",
        "Microsoft.VSTS.Scheduling.OriginalEstimate": "8"
      },
      "relationships": {
        "parent": "{{PBI.ID}}"
      }
    },
    "test_case": {
      "type": "Test Scenario",
      "fields": {
        "System.Title": "{{TestCase.TitleWithoutId}}",
        "System.State": "{{TestCase.State}}",
        "Custom.Components": "{{TestCase.Components}}",
        "Custom.Briefdescription": "{{TestCase.BriefDescription|newlines}}",
        "Custom.Pre_conditions": "{{TestCase.PreCondition|newlines}}",
        "Custom.Teststepswithtestdata": "{{TestCase.TestSteps|newlines}}",
        "Custom.Expectedtestresult": "{{TestCase.ExpectedResult|newlines}}",
        "Custom.Test_type": "{{TestCase.TestApplication}}",
        "Custom.Automationteststatus": "{{TestCase.AutomationStatus}}",
        "Custom.Prioritylevel": "{{TestCase.PriorityLevel}}",
        "Custom.TestScenariobyAI": "Yes",
        "Microsoft.VSTS.Scheduling.Effort": "{{TestCase.Effort}}",
        "Microsoft.VSTS.Scheduling.RemainingWork": "{{TestCase.Effort}}"
      },
      "relationships": {
        "parent": "{{PBI.ID}}"
      }
    }
  },
  "field_transformations": {
    "newlines_formatter": {
      "replace_bullets": true,
      "add_line_breaks": true,
      "bullet_to_html": {
        "- ": "<br>• ",
        "* ": "<br>• ",
        "\n- ": "<br>• ",
        "\n* ": "<br>• "
      },
      "line_break_replacement": {
        "\n": "<br>",
        "\r\n": "<br>",
        "\n\n": "<br><br>"
      },
      "preserve_formatting": {
        "numbered_lists": true,
        "indentation": true,
        "code_blocks": false
      }
    }
  },
  "priority_mapping": {
    "Critical": "1",
    "High": "2",
    "Medium": "3",
    "Low": "4"
  },
  "automation_status_mapping": {
    "Automatable": "Planned",
    "Automated": "Automated",
    "Cannot automate": "Not Applicable"
  },
  "test_application_mapping": {
    "API": "API Testing",
    "Web UI": "Web UI Testing",
    "Mobile UI": "Mobile UI Testing",
    "WindowsApp UI": "WindowsApp UI Testing",
    "Other": "Other"
  },
  "template_variables": {
    "PBI.Title": "sections.1.title",
    "PBI.Description": "sections.1.description",
    "Product Metrics": "sections.2.content",
    "Goal": "sections.3.content",
    "Persona": "sections.4.content",
    "Requirements": "sections.5.content",
    "UX/UI Reference": "sections.6.content",
    "Task.Title": "sections.7.tasks[].title",
    "Task.Description": "sections.7.tasks[].description",
    "TestCase.TitleWithoutId": "test_cases[].title_without_id",
    "TestCase.State": "test_cases[].state",
    "TestCase.Components": "test_cases[].components",
    "TestCase.BriefDescription": "test_cases[].brief_description",
    "TestCase.PreCondition": "test_cases[].pre_condition",
    "TestCase.TestSteps": "test_cases[].test_steps_with_test_data",
    "TestCase.ExpectedResult": "test_cases[].expected_result",
    "TestCase.TestApplication": "test_cases[].test_application",
    "TestCase.AutomationStatus": "test_cases[].automation_status",
    "TestCase.PriorityLevel": "test_cases[].priority_level",
    "TestCase.Effort": "test_cases[].effort",
    "User Flow": "sections.10.content"
  }
}
