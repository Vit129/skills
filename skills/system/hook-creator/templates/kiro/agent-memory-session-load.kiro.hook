{
  "name": "Agent Memory — Session Load",
  "version": "3.0.0",
  "description": "Load agent memory on first prompt. Score-aware search + auto-score matching cases.",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "askAgent",
    "prompt": "This is the first message of the session. Before responding: 1) Read agent-memory/memory.md for current task context, decisions, skill flags, and recent lessons. 2) Search agent-memory/playbook.md for cases matching the user's prompt keywords or active Task_Ledger domains. Prefer cases with higher Applied+Prevented scores. 3) Auto-score: if a matching case's fix is actively applied during this session, increment its Applied column in playbook.md immediately. If recognizing a trigger helped avoid the problem, increment Prevented. 4) Read agent-memory/skill-log.md for recent improvement proposals — apply any 'applied' entries that match the current task domain. 5) If a playbook case references agent-memory/knowledge/, read that file on-demand when the case is actively used — do NOT preload all knowledge files. Do NOT re-read memory on subsequent prompts in this session."
  }
}
