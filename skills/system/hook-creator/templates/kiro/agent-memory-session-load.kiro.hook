{
  "name": "Agent Memory — Session Load",
  "version": "4.0.0",
  "disabled": false,
  "description": "Load agent memory at session start. Read memory.md + search playbook for relevant cases.",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "askAgent",
    "prompt": "[WORKSPACE GUARD: Only execute if the current session context involves files in 'VitProjects/' workspace. If the user is working exclusively in '.claude/' workspace, skip silently.] Read agent-memory/memory.md for current task context, active decisions, and recent lessons. Search agent-memory/playbook.md for cases matching the user's prompt keywords — prefer cases with higher Applied+Prevented scores. If a matching case's fix is applied this session, increment its Applied count. Do NOT re-read on subsequent prompts."
  }
}
