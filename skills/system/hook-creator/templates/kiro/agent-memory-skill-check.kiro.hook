{
  "name": "Agent Memory — Skill Flag Check",
  "version": "2.0.0",
  "disabled": false,
  "description": "After write operations: flag skills that required significant rework. Clear flags after 3 successes.",
  "when": {
    "type": "postToolUse",
    "toolTypes": ["write"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "[WORKSPACE GUARD: Only execute if the current session context involves files in 'VitProjects/' workspace. If the user is working exclusively in '.claude/' workspace, skip silently.] After this write operation: did the skill used require significant rework or produce incorrect output? If yes → add/update Skill_Flag in agent-memory/memory.md (skill path + failure description). If skill was already flagged and this was a success → increment success counter; if counter reaches 3 → remove flag. Only report if flag changed: 📝 Skill flag: [skill] [added/updated/cleared]. Skip if output was correct on first attempt."
  }
}
