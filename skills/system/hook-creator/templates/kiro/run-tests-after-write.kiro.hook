{
  "enabled": true,
  "name": "Run Tests After AI Write",
  "description": "After AI writes a test file, run it automatically.",
  "version": "2.3.0",
  "when": {
    "type": "fileEdited",
    "patterns": ["**/*.spec.ts", "**/*.robot"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Run the file just saved. .spec.ts: npx playwright test [file] --reporter=line | .robot: robot --outputdir results [file]. PASS → '✅ [file] passes'. FAIL → self-heal max 3 attempts, then report."
  }
}
