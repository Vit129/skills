{
  "enabled": true,
  "name": "AIDLC Phase Guard",
  "description": "Enforce documentation sequence before writing files.",
  "version": "4.0.0",
  "when": {
    "type": "preToolUse",
    "toolTypes": ["write"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Skip check if path contains: .kiro/, .claude/, .memory/, planning/, audit.md, or PROGRESS.md. Otherwise, enforce sequence: domain-decomposition → user-stories; domain-design → decomposition; logical-design → design; plan → design; scan/spec → plan. If prerequisite missing → STOP and inform user. If OK → proceed silently."
  }
}
