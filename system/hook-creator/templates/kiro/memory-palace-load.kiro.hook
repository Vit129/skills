{
  "enabled": true,
  "name": "Memory Palace — Load",
  "description": "Load or initialize .memory/ context at session start.",
  "version": "2.3.0",
  "when": {
    "type": "agentStart"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Read .memory/state.md (create if missing with State/Tunnels/Wings/Archive sections). Load Active Wings, Sessions, Threads silently. Inform user: '🏛️ Memory Palace loaded' (or '🏛️ Memory Palace initialized' if newly created). Do NOT show details."
  }
}
