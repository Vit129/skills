{
  "enabled": false,
  "name": "Run Tests After AI Write",
  "description": "Auto-run tests after AI write. Token-efficient.",
  "version": "2.0.0",
  "when": {
    "type": "postToolUse",
    "toolTypes": ["write"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "If written file is test (*.spec.ts/*.robot) → run test. PASS: report '✅ [file] passes'. FAIL: self-heal max 3 times. Else: SILENT."
  }
}
