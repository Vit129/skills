{
  "enabled": false,
  "name": "Run Tests on Save",
  "description": "Auto-run tests on user save. Token-efficient.",
  "version": "2.0.0",
  "when": {
    "type": "fileEdited",
    "patterns": ["**/*.spec.ts"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Test file saved. Run test: `npx playwright test --reporter=line {filePath}`. If FAIL: analyze and suggest fix. Else: SILENT."
  }
}
