{
  "enabled": true,
  "name": "Sync Hook to Templates",
  "description": "Sync edited .kiro.hook files back to the source skill templates.",
  "version": "1.1.0",
  "when": {
    "type": "fileEdited",
    "patterns": [".kiro/hooks/*.kiro.hook"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A hook was edited in .kiro/hooks/. Sync it back:\n1. Find the actual path of 'hook-creator' skill under .claude/skills/ (likely system/ or ai-dlc/core/).\n2. Copy the edited hook to `.../hook-creator/templates/kiro/{filename}`.\n3. Ensure it's listed in the Templates table in hook-creator's SKILL.md.\n4. Confirm: 'Synced {filename} to source templates'."
  }
}
