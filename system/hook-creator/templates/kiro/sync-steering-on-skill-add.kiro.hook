{
  "enabled": true,
  "name": "Sync Steering on New Skill",
  "description": "Auto-create Kiro steering file when a new SKILL.md is added.",
  "version": "1.1.0",
  "when": {
    "type": "fileCreated",
    "patterns": [".claude/skills/**/*.md"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A new file was created in .claude/skills/. If it's a SKILL.md:\n1. Extract {category} and {skill-name} from path.\n2. Create steering at `.kiro/steering/{category}/{skill-name}.md` using standard template (yaml header + title + reference link).\n3. Add entry to `.kiro/steering/STEERING_INDEX.md`.\n4. Confirm: 'Added steering for {skill-name}'."
  }
}
